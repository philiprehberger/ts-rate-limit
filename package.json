{
  "name": "@philiprehberger/rate-limit",
  "version": "0.1.0",
  "description": "In-memory rate limiting for Node.js API routes with configurable windows and presets",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "rate-limit",
    "throttle",
    "api",
    "middleware",
    "security",
    "nodejs"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/philiprehberger/rate-limit"
  },
  "sideEffects": false
}
